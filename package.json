{
  "name": "artsy-browser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "graphql-codegen",
    "dev": "vite",
    "build": "graphql-codegen && vue-tsc -b && vite build",
    "preview": "vite preview",
    "codegen": "graphql-codegen",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@tailwindcss/vite": "^4.2.3",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
